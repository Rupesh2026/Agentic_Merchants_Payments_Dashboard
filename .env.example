# .env.example — copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────
# Stack: Supabase (Postgres + pgvector) · OpenAI · PySpark · Google ADK
# NO Docker. NO Anthropic.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase Postgres ─────────────────────────────────────────────────────────
# Get this from: Supabase Dashboard → Connect → Session pooler (IPv4, port 5432).
# It works from laptops/Windows and supports the session features Spark JDBC +
# SQLAlchemy need.
# Format (session pooler) — the prefix is aws-0 OR aws-1 depending on the project,
# and <region> must match your project's region (copy the exact host from the
# dashboard; do not assume us-east-1):
#   postgresql://postgres.<project_ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
# If your DB password has special characters (@ ! # etc.) that's fine — the app
# URL-encodes it. Direct connection (db.<ref>.supabase.co) is IPv6-only and often
# unreachable from home networks, so prefer the session pooler.
DATABASE_URL=postgresql://postgres.<project_ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Project ref (the subdomain of your project URL https://<project_ref>.supabase.co)
SUPABASE_PROJECT_REF=jshnnfzqgiwcnznwieje

# ── OpenAI (LLM + embeddings — the ONLY model provider) ───────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ── MLflow (experiment tracking) ──────────────────────────────────────────────
# Local file store by default. Run `mlflow ui` to view at http://localhost:5000
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT=payments-fraud-xgboost

# ── Spark (local mode) ────────────────────────────────────────────────────────
# Requires a JDK (17 recommended) on PATH + JAVA_HOME set.
# On Windows you also need HADOOP_HOME + winutils.exe (see README).
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
# Maven coords pulled at runtime via spark.jars.packages (needs internet on first run)
POSTGRES_JDBC_VERSION=42.7.3
DELTA_SPARK_VERSION=3.2.0
